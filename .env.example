# Sao chép thành .env và điền giá trị. CopyHub tự đọc .env khi chạy CLI (thư mục hiện tại).
#
# Google Cloud Console → APIs: bật "Google Sheets API" trên ĐÚNG project của OAuth Client ID
# (nếu copy báo lỗi project=... thì mở link Enable trong log hoặc Library → Google Sheets API → Enable).
# OAuth 2.0 Client → Authorized redirect URIs:
#   http://127.0.0.1:19999/oauth2callback
#
# Spreadsheet ID + nền tảng + phím overlay: nhập sau copyhub login (trang web),
# hoặc copyhub config ... --sheet-id <ID> và chỉnh overlayPlatform / overlayAccelerator trong ~/.copyhub/config.json
# Tab mỗi ngày: COPYHUB-YYYY-MM-DD (múi giờ máy).
#
# copyhub start mặc định mở luôn overlay Electron; đặt 1 để chỉ chạy clipboard + Sheet:
# COPYHUB_START_NO_OVERLAY=1

COPYHUB_GOOGLE_CLIENT_ID=
COPYHUB_GOOGLE_CLIENT_SECRET=
COPYHUB_OAUTH_REDIRECT_PORT=19999

# Phím overlay (tuỳ chọn): nếu đặt ở đây sẽ GHI ĐÈ giá trị đã lưu sau copyhub login (config overlayAccelerator).
COPYHUB_OVERLAY_ACCELERATOR=

# Đặt 1 để KHÔNG tự mở cửa sổ khi chạy overlay (chỉ mở bằng phím / khay).
# COPYHUB_OVERLAY_HIDE_ON_START=1
# Đặt 1 để overlay không tự đóng khi click ra ngoài (mặc định: click ngoài = đóng).
# COPYHUB_OVERLAY_STICKY=1
# Ẩn icon khỏi taskbar khi chạy overlay: COPYHUB_OVERLAY_SKIP_TASKBAR=1
